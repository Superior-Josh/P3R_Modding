# ============================================================
# Git Attributes — 行尾规范化与文件类型标记
# ============================================================

# ── 文本文件 (自动转换行尾) ───────────────────────────────
*               text=auto

# ── 源代码 ───────────────────────────────────────────────
*.cs            text diff=csharp
*.csproj        text diff=xml
*.sln           text eol=crlf
*.ps1           text eol=crlf
*.psm1          text eol=crlf
*.json          text
*.md            text diff=markdown
*.xml            text
*.ini            text

# ── UE4 资产 (二进制) ────────────────────────────────────
*.uasset        binary
*.uexp          binary
*.utoc          binary
*.ucas          binary
*.pak           binary
*.umap          binary
*.uplugin       binary

# ── DLL / 可执行文件 (二进制) ─────────────────────────────
*.dll           binary
*.exe           binary
*.pdb           binary

# ── 归档 (二进制) ─────────────────────────────────────────
*.zip           binary
*.7z            binary
*.rar           binary
