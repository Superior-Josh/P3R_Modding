# ============================================================
# P3R Modding AI Agent — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际路径
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------------
# 必需: 游戏资产目录
# ------------------------------------------------------------------
# Paks 目录包含游戏的 .utoc + .ucas 容器 (IoStore 格式)
# 通常位于游戏安装目录下的 P3R/Content/Paks/
P3R_PAKS_DIR=C:\Program Files (x86)\Steam\steamapps\common\P3R\P3R\Content\Paks

# ------------------------------------------------------------------
# 可选: 输出覆盖
# ------------------------------------------------------------------
# Mod 输出目录 (默认: tools/Output/mod/)
# P3R_MOD_OUTPUT_DIR=

# JSON 缓存目录 (默认: tools/Output/json/)
# P3R_JSON_CACHE_DIR=

# 备份目录 (默认: tools/Output/.backup/)
# P3R_BACKUP_DIR=

# ------------------------------------------------------------------
# 可选: 工具路径覆盖 (默认: tools/ 下自动检测)
# ------------------------------------------------------------------
# P3R_DATA_TOOLS_EXE=
# UNREAL_PAK_EXE=

# ------------------------------------------------------------------
# 可选: AES 密钥 (默认已内置，通常无需修改)
# ------------------------------------------------------------------
# P3R_AES_KEY=0x92BADFE2921B376069D3DE8541696D230BA06B5E4320084DD34A26D117D2FFEE

# ------------------------------------------------------------------
# 可选: 游戏验证
# ------------------------------------------------------------------
# 游戏安装目录 (用于自动安装 .pak 到 Paks/ 和启动验证)
# P3R_GAME_DIR=C:\Program Files (x86)\Steam\steamapps\common\P3R

# ------------------------------------------------------------------
# 可选: Claude Code 配置
# ------------------------------------------------------------------
# Claude Code 模型选择 (默认: claude-fable-5)
# ANTHROPIC_MODEL=claude-fable-5
